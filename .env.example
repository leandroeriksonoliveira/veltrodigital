# Postgres na Vercel (Neon Marketplace)
# Após: Storage → Create Database → Neon no painel do projeto
DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require
# Alternativas injetadas pela Vercel:
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# LLM — use pelo menos uma
OPENAI_API_KEY=sk-...
# ou
ANTHROPIC_API_KEY=sk-ant-...

# Admin do painel /admin/reports
ADMIN_PASSWORD=altere-esta-senha
ADMIN_SESSION_SECRET=gere-um-segredo-longo-aleatorio

# Notificação comercial (opcional)
COMMERCIAL_NOTIFY_WEBHOOK=
COMMERCIAL_NOTIFY_EMAIL=contato@veltrodigital.com.br
