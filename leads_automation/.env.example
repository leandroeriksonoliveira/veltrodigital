# Google Places (opcional — se vazio, usa busca web gratuita)
GOOGLE_PLACES_API_KEY=

# Fonte de leads: auto | web | places | demo
# auto = Places (se tiver chave) → DuckDuckGo web → demo
LEAD_SOURCE=auto
WEB_SEARCH_MAX_PER_QUERY=8
WEB_SEARCH_PAUSE=0.8

# SMTP (Hotmail/Outlook ou outro provedor)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=seu_email@hotmail.com
SMTP_PASSWORD=sua_senha_ou_app_password
EMAIL_FROM=seu_email@hotmail.com
EMAIL_TO=leandro.erikson.oliv@hotmail.com

# Caminhos (relativos à pasta leads_automation/)
EXCEL_PATH=data/leads_conformidade_brasil.xlsx
ROTATION_PATH=data/region_rotation.json
LOG_DIR=logs

# Limites padrão
DEFAULT_LIMIT=20
REQUEST_TIMEOUT=15
